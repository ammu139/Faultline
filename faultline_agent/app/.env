# Faultline ADK 2.0 Agent Configuration
# This .env is used by the ADK agent (app/ directory)

# ─── LLM Configuration ──────────────────────────────────────────────────────
# Uses LiteLLM to connect to any OpenAI-compatible endpoint
OPENAI_API_KEY=<add_api_key>
OPENAI_BASE_URL=http://localhost:6655
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# ─── ADK Configuration ──────────────────────────────────────────────────────
# Uncomment for Google Gemini (AI Studio):
# GOOGLE_API_KEY=your-gemini-api-key
#
# Uncomment for Vertex AI:
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=True

# ─── Simulation Settings ────────────────────────────────────────────────────
SIMULATION_MODE=true
MAX_GRAPH_NODES=200
DEFAULT_PROPAGATION_DEPTH=5
MAX_CASCADE_STEPS=50