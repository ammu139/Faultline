# Faultline Configuration
# Copy this file to .env and fill in your values

# LLM Configuration (Hyperspace AI)
OPENAI_API_KEY=<add_api_key>
OPENAI_BASE_URL=http://localhost:6655
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# Simulation Mode (set to 'false' to use LLM)
SIMULATION_MODE=true #false

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8501
DEBUG=false

# Graph Settings
MAX_GRAPH_NODES=200
DEFAULT_PROPAGATION_DEPTH=5

# Simulation Settings
DEFAULT_SIMULATION_SPEED=1.0
MAX_CASCADE_STEPS=50