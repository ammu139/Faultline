# Faultline Configuration
# Copy this file to .env and fill in your values

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# Simulation Mode (set to 'true' to run without LLM API)
SIMULATION_MODE=true

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8501
DEBUG=false

# Graph Settings
MAX_GRAPH_NODES=200
DEFAULT_PROPAGATION_DEPTH=5

# Simulation Settings
DEFAULT_SIMULATION_SPEED=1.0
MAX_CASCADE_STEPS=50